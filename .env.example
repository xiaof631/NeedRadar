# NeedRadar 环境变量示例
NEEDRADAR_DEBUG=false
NEEDRADAR_DATABASE_URL=postgresql+asyncpg://needradar:needradar@localhost:5406/needradar
# 当需要同步驱动 Alembic 时，可设置同步数据库 URL；未设置时会自动从 asyncpg 映射到 psycopg
# NEEDRADAR_ALEMBIC_DATABASE_URL=postgresql+psycopg://needradar:needradar@localhost:5406/needradar
# 若仅需轻量本地测试，也可临时切回 SQLite：
# NEEDRADAR_DATABASE_URL=sqlite+aiosqlite:///./data/needradar.db
# NEEDRADAR_ALEMBIC_DATABASE_URL=sqlite:///./data/needradar.db
# NEEDRADAR_CELERY_BROKER_URL=redis://localhost:6406/0
# NEEDRADAR_CELERY_RESULT_BACKEND=redis://localhost:6406/1
# 启用简单 API Token 校验时，可配置逗号分隔的 token 列表
# NEEDRADAR_API_TOKENS=dev-token-1,dev-token-2
# 可选：Reddit 数据源抓取配置；未配置 token 时默认回退到公开 RSS
# NEEDRADAR_REDDIT_ACCESS_TOKEN=
# NEEDRADAR_REDDIT_USER_AGENT=NeedRadar/0.1
# 可选：GitHub Issues 数据源抓取配置；共享 IP 下建议配置 token 以避免匿名额度耗尽
# 长期扩源建议使用 GitHub Fine-grained PAT + All public repositories + Issues/Metadata read-only
# NEEDRADAR_GITHUB_ACCESS_TOKEN=
# 可选：YouTube Data API v3
# NEEDRADAR_YOUTUBE_API_KEY=
